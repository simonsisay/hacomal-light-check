BOT_TOKEN=123456:replace-me

# Production-only (webhook mode)
PUBLIC_BASE_URL=https://your-domain.example
WEBHOOK_SECRET=replace-with-a-long-random-string
PORT=3000

# Storage (per-user settings)
# - STORE_BACKEND=auto tries SQLite first, then falls back to JSON if better-sqlite3 native bindings aren't available.
# - STORE_BACKEND=json forces JSON (recommended if you're getting better-sqlite3 binding errors).
STORE_BACKEND=auto
STORE_PATH=./.local/bot.sqlite
