{
  "name": "power-off-telegram-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot that tells each user today's scheduled 1-hour power outage time (18:30/19:30 EAT) and alternates daily.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.6.5",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "start": "cross-env NODE_ENV=development node dist/index.js",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "webhook:set": "tsx src/scripts/register-webhook.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "luxon": "^3.7.2",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.10.2",
    "@types/node-telegram-bot-api": "^0.64.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
