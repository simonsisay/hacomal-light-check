{
  "name": "power-off-telegram-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot that tells each user today's scheduled 1-hour power outage time (18:30/19:30 EAT) and alternates daily.",
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "luxon": "^3.7.2",
    "node-telegram-bot-api": "^0.66.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.10.2",
    "@types/node-telegram-bot-api": "^0.64.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
